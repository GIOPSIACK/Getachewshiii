# Environment variables (copy to a local .env and also set in Vercel)
# Never commit real secrets. Add these in Vercel: Project → Settings → Environment Variables.

# --- Database (Supabase Postgres) ---
# Use the Supabase *pooler* URI (port 6543, includes ?pgbouncer=true) for serverless.
# You can find it at: Supabase → Project → Settings → Database → Connection string → URI.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true

# --- OpenAI (only needed for the /api/chat support assistant) ---
OPENAI_API_KEY=sk-...

# --- Telegram bot ---
# From @BotFather -> /newbot
TELEGRAM_BOT_TOKEN=123456789:AA...
# Optional but recommended: set with `setWebhook` header X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=some-long-random-string

# Vercel sets NODE_ENV=production automatically; listed here for local testing.
NODE_ENV=production
